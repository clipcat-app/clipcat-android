<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Clipcat" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_aqua</item>
        <item name="colorOnPrimary">@color/light_surface</item>
        <item name="colorPrimaryContainer">#E0F7FA</item>
        <item name="colorOnPrimaryContainer">@color/light_text</item>
        <item name="colorSecondary">@color/secondary_pink</item>
        <item name="colorOnSecondary">@color/light_surface</item>
        <item name="colorSecondaryContainer">#FCE4EC</item>
        <item name="colorOnSecondaryContainer">@color/light_text</item>
        
        <item name="android:colorBackground">@color/light_background</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorOnBackground">@color/light_text</item>
        <item name="colorOnSurface">@color/light_text</item>
        
        <item name="android:statusBarColor">@color/light_background</item>
        <item name="android:navigationBarColor">@color/light_background</item>
        <item name="android:windowBackground">@color/light_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        
        <item name="buttonStyle">@style/Widget.Clipcat.Button</item>
        <item name="switchStyle">@style/Widget.Clipcat.Switch</item>
    </style>

    <style name="Widget.Clipcat.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/light_surface</item>
        <item name="strokeColor">@color/light_text</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/light_text</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:fontFamily">sans-serif-condensed-medium</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <!-- Specific button style for the main capture button -->
    <style name="Widget.Clipcat.Button.Capture" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/white</item>
        <item name="strokeColor">@color/black</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/light_surface</item>
        <item name="cornerRadius">40dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="iconPadding">0dp</item>
        <item name="android:fontFamily">sans-serif-condensed-medium</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <!-- Icon button (round) -->
    <style name="Widget.Clipcat.Button.Icon" parent="Widget.Material3.Button.IconButton">
        <item name="backgroundTint">@color/light_surface</item>
        <item name="strokeColor">@color/light_text</item>
        <item name="strokeWidth">2dp</item>
        <item name="iconTint">@color/light_text</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
    </style>

    <style name="Widget.Clipcat.Switch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="trackTint">@color/switch_track_tint</item>
        <item name="thumbTint">@color/switch_thumb_tint</item>
    </style>
</resources>