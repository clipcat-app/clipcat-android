<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/camera_surround">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="12dp"
        android:layout_marginBottom="160dp"
        app:cardBackgroundColor="@color/camera_surround"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.camera.view.PreviewView
                android:id="@+id/previewView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:id="@+id/permissionOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/camera_surround"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Camera permission is required"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/grantPermissionButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grant Permission" />
            </LinearLayout>

            <View
                android:id="@+id/focusIndicator"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/focus_indicator_ring"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/capturePreviewContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clickable="false"
                android:focusable="false"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/capturePreviewCard"
                    android:layout_width="220dp"
                    android:layout_height="300dp"
                    android:layout_gravity="center"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="12dp"
                    app:cardUseCompatPadding="true"
                    app:strokeColor="@color/preview_border"
                    app:strokeWidth="2.2dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/capturePreviewImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:orientation="horizontal"
                android:padding="10dp"
                android:clipToPadding="false"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/previewModeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="10dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="12dp"
                    android:text="FULL"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="11sp"
                    app:backgroundTint="?attr/colorSurface"
                    app:cornerRadius="18dp"
                    app:strokeColor="?attr/colorOnSurface"
                    app:strokeWidth="1.2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/exposureResetButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="12dp"
                    android:text="EV 0.0"
                    android:textAllCaps="false"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="11sp"
                    android:visibility="gone"
                    app:backgroundTint="?attr/colorSurface"
                    app:cornerRadius="18dp"
                    app:strokeColor="?attr/colorOnSurface"
                    app:strokeWidth="1.2dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/settingsButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/rounded_bg_theme"
                    android:src="@drawable/ic_settings"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    app:tint="?attr/colorOnSurface" />
            </LinearLayout>
        </FrameLayout>
            
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/sendProgressContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="24dp"
        android:background="@drawable/rounded_bg_theme"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/sendProgressBar"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:indeterminateTint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/sendProgressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed-medium"
            android:letterSpacing="0.05"
            android:text="SENDING..."
            android:textAllCaps="true"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:id="@+id/zoomControlsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="18dp"
            android:background="@drawable/rounded_bg_theme"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/zoomCollapsedContainer"
                android:layout_width="64dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/zoomCollapsedText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:fontFamily="sans-serif-condensed-medium"
                    android:letterSpacing="0.06"
                    android:text="1.0x"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="17sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/zoomButtonsContainer"
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/zoomHalfButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:maxLines="1"
                    android:paddingHorizontal="4dp"
                    android:gravity="center"
                    android:text="0.5x"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    app:backgroundTint="?attr/colorSurface"
                    app:cornerRadius="20dp"
                    app:strokeColor="?attr/colorOnSurface"
                    app:strokeWidth="1.6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/zoomOneButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:maxLines="1"
                    android:paddingHorizontal="4dp"
                    android:gravity="center"
                    android:text="1x"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    app:backgroundTint="?attr/colorSurface"
                    app:cornerRadius="20dp"
                    app:strokeColor="?attr/colorOnSurface"
                    app:strokeWidth="1.6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/zoomTwoButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:maxLines="1"
                    android:paddingHorizontal="4dp"
                    android:gravity="center"
                    android:text="2x"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    app:backgroundTint="?attr/colorSurface"
                    app:cornerRadius="20dp"
                    app:strokeColor="?attr/colorOnSurface"
                    app:strokeWidth="1.6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/zoomFourButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:maxLines="1"
                    android:paddingHorizontal="4dp"
                    android:gravity="center"
                    android:text="4x"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    app:backgroundTint="?attr/colorSurface"
                    app:cornerRadius="20dp"
                    app:strokeColor="?attr/colorOnSurface"
                    app:strokeWidth="1.6dp" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/zoomSeekBar"
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="1000"
                android:progress="500"
                android:progressTint="?attr/colorPrimary"
                android:thumbTint="?attr/colorOnSurface"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/zoomScaleLabelsRow"
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/zoomMinText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-condensed"
                    android:text="1x"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/zoomCurrentText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-condensed-medium"
                    android:gravity="center"
                    android:text="1.0x"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/zoomMaxText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-condensed"
                    android:gravity="end"
                    android:text="8x"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pairButton"
                style="@style/Widget.Clipcat.Button"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="PAIR PC" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/captureButton"
                style="@style/Widget.Clipcat.Button.Capture"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_centerInParent="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cameraToggleButton"
                style="@style/Widget.Clipcat.Button.Icon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_camera_flip"
                app:iconGravity="textTop"
                app:iconSize="26dp"
                app:iconPadding="0dp" />
        </RelativeLayout>
    </LinearLayout>
</FrameLayout>
